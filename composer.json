{
  "name": "monkeyscloud/monkeyslegion-core",
  "description": "High-performance framework kernel with typed config, service providers, pipeline, and PHP 8.4 primitives for the MonkeysLegion framework.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/container": "^2.0",
    "psr/log": "^3.0",
    "psr/clock": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Core\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Core\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-2.0.0": "2.0.x-dev"
    }
  }
}